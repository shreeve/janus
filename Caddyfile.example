# Ping-only Janus on localhost HTTPS (port 443).
#
#   ./bin/caddy run --config Caddyfile.example
#   curl -sk https://localhost/ping
#   # → pong
#
# Use sudo only if bind to :443 fails with permission denied.
{
	# Local CA + certs for localhost (trust once via: caddy trust)
	auto_https disable_redirects
}

https://localhost {
	tls internal
	janus
}

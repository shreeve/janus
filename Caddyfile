# Janus — capability order: (1) ping, (2) control, (3) cache, (4) hub, (5) mdns
#
# *.ripdev.io → 127.0.0.1; trusted wildcard in ./certs/ (committed on purpose)
#
#   ./bin/caddy run
#
# 1) ping — primordial; needs nothing else
#   Global ping ON.
#   catchall  *.ripdev.io     → inherit on  → pong
#   on.ripdev.io              → explicit on → pong
#   off.ripdev.io             → explicit off → 404
#
#   curl -s https://foo.ripdev.io/ping                                   → pong
#   curl -s https://on.ripdev.io/ping                                    → pong
#   curl -s https://off.ripdev.io/ping -o /dev/null -w '%{http_code}\n'  → 404
#
# 2) control — process-wide /1.0 (after ping chassis)
#   internal → unix  run/janus.sock
#   local    → http  127.0.0.1:7600
#
#   curl -s http://127.0.0.1:7600/1.0
#   curl -s http://127.0.0.1:7600/1.0/health
#   curl -s --unix-socket run/janus.sock http://janus/1.0
#
# on-demand tls (hot ask via /1.0) — minting gated by the registry
#   Cold config owns the machinery (on_demand_tls global + per-site
#   tls { on_demand }); the registry only answers "may we mint for
#   this name?" via GET /1.0/tls/ask?domain=… (200 allow, 404 deny).
#   The :8443 site below mints from Caddy's internal CA on demand:
#   registered hosts complete the handshake, unknown names are denied.
#
#   curl -s 'http://127.0.0.1:7600/1.0/tls/ask?domain=some.host'  → 404 until registered
#
# 3) cache — micro-cache + request coalescing (site-scoped, cascades)
#   Global cache ON (1s default TTL): anonymous GETs on registered hosts
#   are answered from memory for one TTL; concurrent misses coalesce
#   into one worker request. Purged on every upstreams PUT / DELETE /
#   reap / host claim (generation-fenced).
#   catchall  *.ripdev.io  → inherit on  (default tuning, no debug)
#   api.ripdev.io          → explicit off (auth via custom headers must
#                            never meet a shared cache)
#   pages.ripdev.io        → ttl 5s override + X-Janus-Cache debug header
#
#   curl -s http://127.0.0.1:7600/1.0/cache        → hit/miss counters
#
# 4) hub — per-app WebSocket fan-out (site-scoped, cascades)
#   Global hub ON (path /hub, origin same): upgrades on registered hosts
#   terminate at Janus; frames fan out at the edge; the tenant observes
#   through its hot-registered bridge_path and steers via
#   POST /1.0/apps/{id}/hub/publish.
#   catchall   *.ripdev.io   → inherit on (default tuning, origin same)
#   api.ripdev.io            → explicit off (plain HTTP API site)
#   hubany.ripdev.io         → origin any (token-authenticated non-browser clients)
#   hubten/hubtwenty         → max_conns 10 / 20 (per-app floor = 10 when
#                              one app claims both)
#
#   curl -s http://127.0.0.1:7600/1.0/hub          → hub counters
#
# 5) mdns — LAN presence (process-wide, like control)
#   Enabling announces this machine and its app list to the local
#   network, and serves the read-only status front door on every
#   interface. janus.local + every registered single-label .local host
#   advertise over multicast DNS; the front door renders the registry,
#   cache, and hub at a glance. listen :7680 pins dedicated mode here so
#   the dev config (and ./test.sh) runs unprivileged; the production
#   default (no listen) is shared mode — the front door rides inside
#   the :80 HTTP server behind an http://*.local site block (see
#   Caddyfile.example).
#
#   curl -s http://127.0.0.1:7600/1.0/mdns             → advertiser state
#   curl -s -H 'Host: janus.local' http://127.0.0.1:7680/status.json
#
{
	auto_https disable_redirects # the redirect server would bind :80; this dev/CI config runs unprivileged
	skip_install_trust

	on_demand_tls {
		ask http://127.0.0.1:7600/1.0/tls/ask
	}

	janus {
		ping # 1) site-scoped default: on
		control internal # 2) process-wide
		control local
		cache { # 3) site-scoped default: on, tuned
			ttl 1s
			ttl_max 10s
			max_body 256kb
			max_bytes 64mb # process-wide pool (GLOBAL ONLY)
			max_app_share 50 # % of max_bytes one app may hold (GLOBAL ONLY)
		}
		hub # 4) site-scoped default: on (path /hub, origin same)
		mdns { # 5) process-wide LAN presence
			listen :7680 # dedicated dev/test listener; default (no listen) shares the :80 HTTP server
		}
	}
}

(ripdev_tls) {
	tls certs/ripdev.io.crt certs/ripdev.io.key
}

# Catchall — any other *.ripdev.io name inherits global ping on
*.ripdev.io {
	import ripdev_tls
	janus
}

# Explicit on (same effective result as catchall; proves site-level on)
on.ripdev.io {
	import ripdev_tls
	janus {
		ping on
	}
}

# Explicit off
off.ripdev.io {
	import ripdev_tls
	janus {
		ping off
	}
}

# Cache + hub: explicit off beats inherited on (custom-header auth and a
# shared cache must never meet; a plain HTTP API site speaks no hub)
api.ripdev.io {
	import ripdev_tls
	janus {
		cache off
		hub off
	}
}

# Cache: per-key override — ttl 5s, debug header while developing
pages.ripdev.io {
	import ripdev_tls
	janus {
		cache {
			ttl 5s
			debug
		}
	}
}

# Hub: origin any — token-authenticated non-browser clients (and test
# drivers) that send no Origin header
hubany.ripdev.io {
	import ripdev_tls
	janus {
		hub {
			origin any
		}
	}
}

# Hub: tightly capped sites — one app claiming both is floored at 10
hubten.ripdev.io {
	import ripdev_tls
	janus {
		hub {
			max_conns 10
			origin any
		}
	}
}

hubtwenty.ripdev.io {
	import ripdev_tls
	janus {
		hub {
			max_conns 20
			origin any
		}
	}
}

# On-demand TLS — certs minted per SNI from the internal CA, but only
# for names the registry allows (see on_demand_tls ask above).
# Hub off: this catch-all site would otherwise make EVERY host
# hub-enabled, defeating per-host hub admission.
https://:8443 {
	tls {
		on_demand
		issuer internal
	}
	janus {
		hub off
	}
}
